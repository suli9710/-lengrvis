MARVIS_PROVIDER_NAME=openai_compatible
MARVIS_BASE_URL=https://api.openai.com/v1
# 留空时 efficiency / hybrid 可按 MARVIS_ALLOW_MOCK_FALLBACK 使用 MockProvider 做开发演示。
# privacy 模式不会使用 MockProvider 兜底，必须检测到 Ollama / LM Studio / llama.cpp-compatible server。
MARVIS_API_KEY=
MARVIS_MODEL=gpt-4o-mini
MARVIS_MODEL_CONTEXT_WINDOW=128000
MARVIS_MODEL_AUTO_COMPACT_TOKEN_LIMIT=96000
MARVIS_ONNX_MODEL_PATH=
MARVIS_ONNX_EXECUTION_PROVIDER=
MARVIS_EMBEDDING_MODEL=text-embedding-3-small
MARVIS_CONTEXT_AUTO_COMPACT_ENABLED=true
MARVIS_CONTEXT_MICRO_COMPACT_ENABLED=true
MARVIS_CONTEXT_HISTORY_SNIP_ENABLED=true
MARVIS_CONTEXT_SESSION_MEMORY_ENABLED=true
MARVIS_CONTEXT_WARNING_BUFFER_TOKENS=20000
MARVIS_CONTEXT_ERROR_BUFFER_TOKENS=20000
MARVIS_CONTEXT_MANUAL_COMPACT_BUFFER_TOKENS=3000
MARVIS_CONTEXT_RECENT_MESSAGE_LIMIT=24
MARVIS_CONTEXT_MICRO_COMPACT_AGE=8
MARVIS_CONTEXT_MICRO_COMPACT_TOOL_RESULT_CHARS=1200
MARVIS_CONTEXT_HISTORY_SNIP_THRESHOLD=160
MARVIS_CONTEXT_HISTORY_SNIP_KEEP_RECENT=80
MARVIS_CONTEXT_SESSION_SUMMARY_LIMIT=12000
MARVIS_LLM_API_MAX_RETRIES=2
MARVIS_LLM_API_RETRY_BACKOFF_SECONDS=0.25
MARVIS_LLM_API_CIRCUIT_FAILURE_THRESHOLD=5
MARVIS_LLM_API_CIRCUIT_COOLDOWN_SECONDS=30.0
# privacy = 本地 LLM 后端可用时运行；efficiency = 云端 provider；hybrid = 规划可上云、执行优先本地。
MARVIS_MODE=efficiency
MARVIS_ALLOW_CLOUD_CONTEXT=false
MARVIS_ALLOW_FILE_CONTENT_UPLOAD=false
MARVIS_ALLOW_BROWSER_NETWORK=false
MARVIS_STRICT_STATE_MACHINE=false
MARVIS_RECOVERY_MAX_RETRIES=3
MARVIS_EXECUTION_ENGINES=dual
MARVIS_DEFAULT_ENGINE=auto
MARVIS_AGENT_LOOP_MAX_TURNS=30
MARVIS_RUN_EVENT_RETENTION_DAYS=30
MARVIS_JWT_SECRET=
# 控制非隐私路径缺少真实 provider 时是否允许 MockProvider 演示兜底。
# 注意：privacy 模式探测不到本地后端时始终直接报错，不受此开关影响。
MARVIS_ALLOW_MOCK_FALLBACK=true
MARVIS_APP_ALLOWLIST=notepad;calculator;calc
MARVIS_BROWSER_MAX_PAGE_BYTES=250000
MARVIS_DOCUMENT_MAX_CHARS_TO_LLM=30000
MARVIS_BROWSER_SCREENSHOT_DIR=
MARVIS_ALLOWED_DIRECTORIES=
MARVIS_SKILL_DIRECTORIES=

MAVRIS_BACKEND_URL=http://127.0.0.1:8000
MAVRIS_BACKEND_COMMAND=python
MAVRIS_BACKEND_ARGS=-m uvicorn backend.main:app --host 127.0.0.1 --port 8000
